#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

DEB_BUILD_OPTIONS := nostrip nocheck
export DEB_BUILD_OPTIONS

PG_BUILDEXT = /usr/bin/pg_buildext
export PG_UPDATECONTROL=1

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_clean:
	pg_buildext clean build-%v
	rm -rf spqrhash

override_dh_auto_build:
	pg_buildext build build-%v

override_dh_auto_install: 
	make html
	PG_SUPPORTED_VERSIONS=installed pg_buildext install build-%v postgresql-%v-spqrhash

%:
	dh $@

.PHONY: orig realclean
PKGVERS = $(shell dpkg-parsechangelog | awk -F '[:-]' '/^Version:/ { print substr($$2, 2) }')
srcpkg = spqrhash_$(PKGVERS)
srctar = $(srcpkg).orig.tar.gz
dst = ext/$(srcpkg)
orig:
	rm -rf ext
	mkdir -p $(dst)
	git archive HEAD | tar xf - -C $(dst)
	rm -rf $(dst)/debian
	cd ext && tar czf ../../$(srctar) $(srcpkg)
	rm -rf ext

realclean:
	rm -rf debian/tmp debian/*.log debian/*.substvars
	rm -f debian/control-stamp debian/files
	for v in `cat debian/pgversions`; do rm -rf debian/postgresql-$${v}-spqrhash; done
	grep-dctrl -vP PGVERSION debian/control.in > debian/control

